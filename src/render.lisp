(defun label (key)
  (getf (cdr (assoc *current-language* *language-labels*)) key))

(defun current-course-title ()
  (course-title-for-language *current-language*))

(defun current-course-deck ()
  (course-deck-for-language *current-language*))

(defun current-lessons ()
  (lessons-for-language *current-language*))

(defun localized-page-url (target-language filename)
  (cond
    ((eq target-language *current-language*) filename)
    ((eq target-language :en) (format nil "../~A" filename))
    (t (format nil "pt-br/~A" filename))))

(defun asset-url (filename)
  (if (eq *current-language* :en)
      (format nil "assets/~A" filename)
      (format nil "../assets/~A" filename)))

(defun ensure-directory (pathname)
  (ensure-directories-exist (merge-pathnames "sentinel" pathname))
  pathname)

(defun path (directory name)
  (merge-pathnames name directory))

(defun escape-html (value)
  (with-output-to-string (stream)
    (loop for character across (princ-to-string value) do
      (case character
        (#\< (write-string "&lt;" stream))
        (#\> (write-string "&gt;" stream))
        (#\& (write-string "&amp;" stream))
        (#\" (write-string "&quot;" stream))
        (#\' (write-string "&#39;" stream))
        (otherwise (write-char character stream))))))

(defun html-attrs (attrs)
  (with-output-to-string (stream)
    (loop for (name value) on attrs by #'cddr
          when value do
            (format stream " ~A=\"~A\"" name (escape-html value)))))

(defun element (name attrs &rest body)
  (with-output-to-string (stream)
    (format stream "<~A~A>" name (html-attrs attrs))
    (dolist (part body)
      (write-string part stream))
    (format stream "</~A>" name)))

(defun void-element (name attrs)
  (format nil "<~A~A>" name (html-attrs attrs)))

(defun link-to (href label &key class)
  (element "a" (list "href" href "class" class) (escape-html label)))

(defun code-block (code)
  (element "pre" '("class" "code")
           (element "code" '() (escape-html code))))

(defun paragraph-html (text)
  (element "p" '() (escape-html text)))

(defun slug-file (lesson)
  (format nil "~A.html" (lesson-slug lesson)))

(defun lesson-url (lesson)
  (slug-file lesson))

